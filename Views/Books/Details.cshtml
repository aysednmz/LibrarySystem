@model Book

@{
    ViewData["Title"] = "Book Details";
}

<h1>Book Details</h1>

<div class="card">
    <div class="card-body">
        <h3 class="card-title">@Model.Title</h3>
        <p class="mb-1"><strong>Author:</strong> @Model.Author</p>
        <p class="mb-1"><strong>Category:</strong> @Model.Category</p>
        <p class="mb-1"><strong>Published Year:</strong> @Model.PublishedYear</p>
        <p class="mb-3"><strong>Description:</strong> @Model.Description</p>

        <p>
            <strong>Availability:</strong>
            <span class="badge bg-@(Model.AvailableCopies > 0 ? "secondary" : "danger")">
                @Model.AvailableCopies / @Model.TotalCopies
            </span>
        </p>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Index" class="btn btn-info text-white">All Books</a>

    @if (User.Identity != null && User.Identity.IsAuthenticated && Model.AvailableCopies > 0)
    {
        <a asp-controller="Borrowings" asp-action="Borrow" asp-route-id="@Model.Id" class="btn btn-secondary text-white">Borrow</a>
    }

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
    }
</div>
