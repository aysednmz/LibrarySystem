@model Book

@{
    ViewData["Title"] = "Delete Book";
}

<h1>Delete Book</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this book?</h3>
</div>

<div class="card">
    <div class="card-body">
        <h4>@Model.Title</h4>
        <hr />
        <dl class="row">
            <dt class="col-sm-3">Author:</dt>
            <dd class="col-sm-9">@Model.Author</dd>

            <dt class="col-sm-3">Published Year:</dt>
            <dd class="col-sm-9">@Model.PublishedYear</dd>

            <dt class="col-sm-3">Category:</dt>
            <dd class="col-sm-9">@Model.Category</dd>

            <dt class="col-sm-3">Total Copies:</dt>
            <dd class="col-sm-9">@Model.TotalCopies</dd>

            <dt class="col-sm-3">Available Copies:</dt>
            <dd class="col-sm-9">@Model.AvailableCopies</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>