@model IEnumerable<Book>

@{
    ViewData["Title"] = "Books";
    var categories = ViewData["Categories"] as List<string> ?? new List<string>();
}

<h1>Books</h1>

<form asp-action="Index" method="get" class="mb-3">
    <div class="row g-2">
        <div class="col-md-5">
            <input name="q" value="@(ViewData["Query"] as string)" class="form-control" placeholder="Search by title or author" />
        </div>
        <div class="col-md-4">
            <select name="category" class="form-select">
                <option value="">All categories</option>
                @foreach (var c in categories)
                {
                    <option value="@c" selected="@(c == (ViewData["Category"] as string))">@c</option>
                }
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-warning flex-grow-1">Filter</button>
            <a asp-action="Index" class="btn btn-outline-secondary flex-grow-1">Clear</a>
        </div>
    </div>
</form>

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Add New Book</a>
    </p>
}

<div class="table-responsive">
    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Category</th>
                <th>Available</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Title</strong></td>
                    <td>@item.Author</td>
                    <td>@item.Category</td>
                    <td>
                        <span class="badge bg-@(item.AvailableCopies > 0 ? "secondary" : "danger")">
                            @item.AvailableCopies / @item.TotalCopies
                        </span>
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Details</a>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            if (item.AvailableCopies > 0)
                            {
                                <a asp-controller="Borrowings" asp-action="Borrow" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Borrow</a>
                            }
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
