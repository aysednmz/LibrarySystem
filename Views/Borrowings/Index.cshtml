@model IEnumerable<Borrowing>

@{
    ViewData["Title"] = "All Borrowings";
    int currentPage = ViewData["CurrentPage"] != null ? (int)ViewData["CurrentPage"] : 1;
    int totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
}

<h1>All Borrowings (Admin Page)</h1>

<!-- Filter by Status -->
<form asp-action="Index" method="get" class="mb-3">
    <div class="row g-2">
        <div class="col-md-4">
            <select name="status" class="form-select">
                <option value="">All Statuses</option>
                @if (ViewData["Statuses"] != null)
                {
                    foreach (var st in ViewData["Statuses"] as List<string>)
                    {
                        <option value="@st" selected="@(st == ViewData["Status"] as string)">
                            @st
                        </option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-warning w-100">Filter</button>
        </div>
        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
        </div>
    </div>
</form>

<!-- Borrowings Table -->
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Book</th>
                <th>Borrower</th>
                <th>Borrow Date</th>
                <th>Due Date</th>
                <th>Return Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Book?.Title</strong></td>
                    <td>@item.User?.UserName</td>
                    <td>@item.BorrowDate.ToString("MMM dd, yyyy")</td>
                    <td class="@(item.DueDate < DateTime.Now && item.Status == "Borrowed" ? "text-danger" : "")">
                        @item.DueDate.ToString("MMM dd, yyyy")
                    </td>
                    <td>@(item.ReturnDate?.ToString("MMM dd, yyyy") ?? "-")</td>
                    <td>
                        <span
                            class="badge bg-@(item.Status == "Returned" ? "primary" : item.Status == "Borrowed" ? "warning" : "danger")">
                            @item.Status
                        </span>
                    </td>
                    <td>
                        @if (item.Status == "Borrowed" || item.Status == "Overdue")
                        {
                            <form asp-action="Return" asp-route-id="@item.Id" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-primary"
                                    onclick="return confirm('Mark this book as returned?')">
                                    Return
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@if (totalPages > 1)
{
    <nav aria-label="Borrowings pagination">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)"
                    asp-route-status="@ViewData["Status"]">
                    Previous
                </a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-status="@ViewData["Status"]">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)"
                    asp-route-status="@ViewData["Status"]">
                    Next
                </a>
            </li>
        </ul>
    </nav>
}